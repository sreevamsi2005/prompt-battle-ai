# fal.ai API Key — get yours at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key-here

# Optional: multiple fal.ai keys for a busy booth. When set, FAL_KEYS takes
# priority over FAL_KEY — video generation requests round-robin across every
# key listed here, and automatically retry with the next key if one is
# rejected, rate-limited, or out of credits. Comma-separated, no spaces needed.
# FAL_KEYS=key-one,key-two,key-three

# OpenAI (for prompt scoring — optional, falls back to mock scorer)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini — used for prompt scoring fallback AND video similarity
# (video similarity uses the gemini-embedding-2 multimodal model). Get a free
# key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Admin panel password (/admin, /admin/logs). Defaults to "booth2024" if
# unset — change this before running a real event.
ADMIN_PASSWORD=your-admin-password-here
